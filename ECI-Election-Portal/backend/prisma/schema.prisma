generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  name          String?
  epicNumber    String?     @unique
  role          Role        @default(VOTER)
  createdAt     DateTime    @default(now())
  grievances    Grievance[]
}

enum Role {
  VOTER
  ADMIN
  OFFICIAL
}

model Candidate {
  id              String   @id @default(uuid())
  name            String
  party           String
  constituency    String
  state           String
  electionType    ElectionType @default(LOK_SABHA)
  phase           Int      @default(1)
  year            Int      @default(2024)
  assets          BigInt
  criminalCases   Int      @default(0)
  education       String
  photoUrl        String?
  socialTwitter   String?
  socialFacebook  String?
  socialInstagram String?
  socialWebsite   String?
  affidavitUrl    String?

  @@index([state])
  @@index([party])
  @@index([electionType])
  @@index([constituency])
}

enum ElectionType {
  LOK_SABHA
  RAJYA_SABHA
  VIDHAN_SABHA
  LOCAL_GOVT
}

model Grievance {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String
  description String
  state       String
  district    String?
  constituency String?
  evidenceUrl String?
  isAnonymous Boolean  @default(false)
  status      Status   @default(FILED)
  severity    Severity @default(MEDIUM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Status {
  FILED
  UNDER_REVIEW
  INVESTIGATED
  RESOLVED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Turnout {
  id             String   @id @default(uuid())
  constituency   String
  state          String
  predicted      Float
  actual         Float?
  timestamp      DateTime @default(now())
}

model VoterRegistration {
  id          String   @id @default(uuid())
  name        String
  email       String
  phoneNo     String
  aadhaarNo   String   @unique
  voterId     String   @unique
  birthday    String?
  createdAt   DateTime @default(now())
}
